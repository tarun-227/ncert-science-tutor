# ── AI ──────────────────────────────────────────────────────────────────────
GROQ_API_KEY=gsk_your_key_here

# ── Supabase (backend — service key, never expose publicly) ──────────────────
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJ...your_service_role_key...
SUPABASE_JWT_SECRET=your-jwt-secret-from-supabase-settings

# ── Supabase (frontend — anon key, safe to expose) ───────────────────────────
# Also set VITE_SUPABASE_URL and VITE_SUPABASE_ANON_KEY as Railway build args
VITE_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...your_anon_key...
